#!/usr/bin/env python3
"""Export the latest completed Codex run and build a clean share package.

The default sanitized package contains only:
  * the AFR JSON export for that single run, with obvious secrets redacted
  * a receipt with checksums and provenance

The raw terminal transcript is sensitive and is excluded by default.  It can
be included (also redacted) with --include-raw-transcript, but the resulting
package should still be reviewed before sharing.

Failed, running, and stale sessions are excluded because the script only
considers AFR runs whose status is `completed` and whose metadata says
`agent == "codex"`.
"""

from __future__ import annotations

import argparse
import datetime
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tarfile
from pathlib import Path
from typing import Any


# Text redaction patterns.  Order matters: more specific patterns first.
_TEXT_PATTERNS: list[tuple[re.Pattern[str], str]] = [
    # Private key blocks (PEM / OPENSSH / PGP).
    (
        re.compile(
            r"-----BEGIN (?:RSA |OPENSSH |EC |DSA |PGP )?PRIVATE KEY-----"
            r".*?"
            r"-----END (?:RSA |OPENSSH |EC |DSA |PGP )?PRIVATE KEY-----",
            re.DOTALL | re.IGNORECASE,
        ),
        "<REDACTED-PRIVATE-KEY>",
    ),
    # OPENAI_API_KEY=... or OPENAI_API_KEY: ...
    (
        re.compile(r"(?i)(OPENAI_API_KEY\s*[:=]\s*)[^\s\"'\r\n]+", re.IGNORECASE),
        r"\1<REDACTED>",
    ),
    # Generic sensitive key/value pairs.
    (
        re.compile(
            r"(?i)"
            r"(?:password|token|secret|api_key|apikey|auth_token|access_token|"
            r"refresh_token|id_token|bearer)\s*[:=]\s*['\"]?[^\"'\s\r\n]+",
        ),
        "<REDACTED-CREDENTIAL>",
    ),
    # Authorization header (Bearer or other).
    (
        re.compile(r"(?i)(Authorization\s*:\s*)[^\r\n]+", re.IGNORECASE),
        r"\1<REDACTED>",
    ),
    # Cookie header.
    (
        re.compile(r"(?i)(Cookie\s*:\s*)[^\r\n]+", re.IGNORECASE),
        r"\1<REDACTED>",
    ),
    # sk-... API keys.
    (
        re.compile(r"\b(sk-[a-zA-Z0-9_-]{10,})\b", re.IGNORECASE),
        "sk-<REDACTED>",
    ),
    # auth.json paths.
    (
        re.compile(r"(?i)([^\s\"']*auth\.json)", re.IGNORECASE),
        "<REDACTED-AUTH-PATH>",
    ),
]

# JSON object keys whose values should be fully redacted.
_SENSITIVE_JSON_KEYS: set[str] = {
    "api_key",
    "apikey",
    "auth",
    "authorization",
    "cookie",
    "password",
    "token",
    "secret",
    "secrets",
    "private_key",
    "access_token",
    "refresh_token",
    "id_token",
    "bearer",
    "auth_token",
    "openai_api_key",
    "openai_api_key",
}


def _repo_root() -> Path:
    return Path(__file__).resolve().parent


def _api_url() -> str:
    return os.environ.get("AFR_API_URL", "http://127.0.0.1:8700").rstrip("/")


def _afr_root() -> Path:
    return Path(os.environ.get("AFR_ROOT") or _repo_root())


def _afr_bin() -> Path:
    return Path(os.environ.get("AFR_BIN") or (_repo_root().parent / ".venv" / "bin" / "afr"))


def _run_prefix(run_id: str) -> str:
    return run_id.split("-")[0]


def _sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _afr_json(args: list[str]) -> dict | list:
    cmd = [str(_afr_bin()), "--json", "-A", _api_url(), *args]
    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    if not result.stdout.strip():
        return {}
    return json.loads(result.stdout)


def completed_codex_runs(limit: int = 20) -> list[dict]:
    runs = _afr_json(["runs", "list", "--status", "completed", "--limit", str(limit)])
    if not isinstance(runs, list):
        return []
    return [r for r in runs if isinstance(r, dict) and r.get("metadata", {}).get("agent") == "codex"]


def latest_completed_codex_run_id() -> str:
    runs = completed_codex_runs(limit=10)
    if not runs:
        raise RuntimeError("No completed Codex run found.")
    return runs[0]["id"]


def export_run(run_id: str, output: Path) -> None:
    output.parent.mkdir(parents=True, exist_ok=True)
    cmd = [str(_afr_bin()), "-A", _api_url(), "export", run_id, "-o", str(output)]
    subprocess.run(cmd, check=True)


def _redact_text(text: str) -> str:
    """Redact obvious secret patterns from a free-form string."""
    for pattern, replacement in _TEXT_PATTERNS:
        text = pattern.sub(replacement, text)
    return text


def _redact_json(obj: Any) -> Any:
    """Recursively redact secrets from a JSON-serializable object."""
    if isinstance(obj, dict):
        redacted: dict[str, Any] = {}
        for key, value in obj.items():
            if isinstance(key, str) and key.lower() in _SENSITIVE_JSON_KEYS:
                redacted[key] = "<REDACTED>"
            elif isinstance(value, str):
                redacted[key] = _redact_text(value)
            else:
                redacted[key] = _redact_json(value)
        return redacted
    if isinstance(obj, list):
        return [_redact_json(item) for item in obj]
    if isinstance(obj, str):
        return _redact_text(obj)
    return obj


def _write_redacted_json(src: Path, dst: Path) -> None:
    """Read JSON from src, redact it, and write pretty-printed JSON to dst."""
    with src.open("r", encoding="utf-8") as f:
        data = json.load(f)
    redacted = _redact_json(data)
    dst.parent.mkdir(parents=True, exist_ok=True)
    with dst.open("w", encoding="utf-8") as f:
        json.dump(redacted, f, indent=2, ensure_ascii=False)
        f.write("\n")


def _write_redacted_text(src: Path, dst: Path) -> None:
    """Read text from src, redact it, and write to dst."""
    with src.open("r", encoding="utf-8", errors="replace") as f:
        text = f.read()
    redacted = _redact_text(text)
    dst.parent.mkdir(parents=True, exist_ok=True)
    with dst.open("w", encoding="utf-8") as f:
        f.write(redacted)


def build_package(run_id: str, *, include_raw_transcript: bool = False) -> dict:
    afr_root = _afr_root().resolve()
    prefix = _run_prefix(run_id)

    export_dir = afr_root / "exports"
    share_dir = afr_root / "share"
    package_name = f"codex-clean-{prefix}-raw" if include_raw_transcript else f"codex-clean-{prefix}"
    clean_dir = share_dir / package_name
    tar_path = share_dir / f"{package_name}.tar.gz"

    raw_export_path = export_dir / f"codex-trace-{prefix}.json"
    transcript_dir = afr_root / ".afr" / "codex" / run_id
    transcript_path = transcript_dir / "terminal-transcript.txt"

    if include_raw_transcript and not transcript_path.exists():
        raise RuntimeError(f"Transcript not found for run {run_id}: {transcript_path}")

    if clean_dir.exists():
        shutil.rmtree(clean_dir)
    if tar_path.exists():
        tar_path.unlink()

    export_run(run_id, raw_export_path)

    clean_dir.mkdir(parents=True)

    # Always redact the exported trace before placing it in the share package.
    clean_export_path = clean_dir / raw_export_path.name
    _write_redacted_json(raw_export_path, clean_export_path)

    transcript_sha: str | None = None
    transcript_rel: str | None = None
    if include_raw_transcript:
        clean_transcript_path = clean_dir / transcript_path.name
        if transcript_path.exists():
            _write_redacted_text(transcript_path, clean_transcript_path)
            transcript_sha = _sha256_file(clean_transcript_path)
            transcript_rel = str(clean_transcript_path.relative_to(afr_root))

    receipt: dict[str, Any] = {
        "run_id": run_id,
        "export_path": str(clean_export_path.relative_to(afr_root)),
        "package_path": str(tar_path.relative_to(afr_root)),
        "raw_transcript_is_sensitive": True,
        "raw_transcript_included": include_raw_transcript,
        "redacted": True,
        "created_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    if transcript_rel:
        receipt["transcript_path"] = transcript_rel
        receipt["transcript_sha256"] = transcript_sha
    else:
        receipt["transcript_path"] = None
        receipt["transcript_sha256"] = None

    if include_raw_transcript:
        receipt["note"] = (
            "Raw terminal transcript included by request and redacted; "
            "review before sharing."
        )
    else:
        receipt["note"] = (
            "Raw terminal transcript is sensitive and excluded by default; "
            "use --include-raw-transcript to include a redacted copy."
        )

    receipt_path = clean_dir / "receipt.json"
    with receipt_path.open("w", encoding="utf-8") as f:
        json.dump(receipt, f, indent=2)
        f.write("\n")

    with tarfile.open(tar_path, "w:gz") as tar:
        tar.add(clean_dir, arcname=clean_dir.name)

    package_sha = _sha256_file(tar_path)
    receipt["package_sha256"] = package_sha

    with receipt_path.open("w", encoding="utf-8") as f:
        json.dump(receipt, f, indent=2)
        f.write("\n")

    if tar_path.exists():
        tar_path.unlink()
    with tarfile.open(tar_path, "w:gz") as tar:
        tar.add(clean_dir, arcname=clean_dir.name)
    package_sha = _sha256_file(tar_path)
    receipt["package_sha256"] = package_sha

    return {
        "run_id": run_id,
        "prefix": prefix,
        "export_path": str(raw_export_path),
        "transcript_path": str(transcript_path),
        "clean_dir": str(clean_dir),
        "tar_path": str(tar_path),
        "package_sha256": package_sha,
        "transcript_sha256": transcript_sha,
        "receipt": receipt,
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="Build a clean share package for the latest completed Codex run.")
    parser.add_argument("run_id", nargs="?", help="Run UUID or prefix (default: latest completed Codex run)")
    parser.add_argument(
        "--include-raw-transcript",
        action="store_true",
        help="Include a redacted copy of the raw terminal transcript in the package (default: excluded)",
    )
    args = parser.parse_args()

    try:
        if args.run_id:
            run_id = args.run_id.strip().lower()
            if len(run_id) != 36 or run_id.count("-") != 4:
                matches = [r["id"] for r in completed_codex_runs() if str(r.get("id", "")).lower().startswith(run_id)]
                if len(matches) != 1:
                    print(f"Could not resolve run prefix {args.run_id!r} to a single completed Codex run.", file=sys.stderr)
                    return 1
                run_id = matches[0]
        else:
            run_id = latest_completed_codex_run_id()

        result = build_package(run_id, include_raw_transcript=args.include_raw_transcript)

        print(f"Packaged latest completed Codex run: {result['run_id']}")
        print(f"  export:     {result['export_path']}")
        print(f"  transcript: {result['transcript_path']}")
        print(f"  clean dir:  {result['clean_dir']}")
        print(f"  tarball:    {result['tar_path']}")
        print(f"  package sha256: {result['package_sha256']}")
        if args.include_raw_transcript:
            print("  included:   redacted raw transcript")
        else:
            print("  included:   redacted export only (raw transcript excluded)")

    except subprocess.CalledProcessError as exc:
        print(f"AFR CLI command failed: {exc}", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr, file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
