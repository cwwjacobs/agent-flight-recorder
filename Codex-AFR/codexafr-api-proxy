#!/usr/bin/env python3
"""OpenAI-compatible API proxy for Codex AFR capture.

Usage:
    codexafr-api-proxy --run-id RUN_ID [--afr-api-url URL]

The proxy prints its local URL on stdout (first line), then listens until
stdin closes or it receives SIGTERM.  It forwards Codex traffic to the real
OpenAI API while emitting model_call / tool_call / tool_result events to the
AFR backend.
"""

from __future__ import annotations

import argparse
import json
import os
import signal
import socket
import sys
import threading
import time
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any

DEFAULT_AFR_API_URL = "http://127.0.0.1:8700"
DEFAULT_OPENAI_API_BASE = "https://api.openai.com"

_run_id: str | None = None
_afr_api_url: str = DEFAULT_AFR_API_URL
_afr_token: str | None = None


def _log(msg: str) -> None:
    print(f"[codexafr-api-proxy] {msg}", file=sys.stderr)


def afr_post(path: str, body: dict[str, Any]) -> dict[str, Any] | None:
    """POST a JSON body to the AFR API; failures are logged but not fatal."""
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        _afr_api_url.rstrip("/") + path,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    if _afr_token:
        req.add_header("Authorization", f"Bearer {_afr_token}")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            raw = resp.read()
            return json.loads(raw.decode("utf-8")) if raw else None
    except urllib.error.HTTPError as exc:
        _log(f"AFR API error: {exc.code} {exc.reason}")
        try:
            _log(exc.read().decode("utf-8", errors="replace")[:500])
        except Exception:
            pass
    except Exception as exc:
        _log(f"AFR API request failed: {exc}")
    return None


def emit_event(event_type: str, name: str, payload: dict[str, Any]) -> None:
    if not _run_id:
        return
    afr_post(f"/runs/{_run_id}/events", {
        "event_type": event_type,
        "name": name,
        "payload": payload,
    })


def summarize_messages(messages: list[dict[str, Any]]) -> dict[str, Any]:
    """Return a compact summary of a chat-style message list."""
    counts: dict[str, int] = {}
    for m in messages:
        role = m.get("role", "unknown")
        counts[role] = counts.get(role, 0) + 1
    return {
        "message_count": len(messages),
        "role_counts": counts,
        "last_roles": [m.get("role") for m in messages[-3:]],
    }


def summarize_tool_args(args: dict[str, Any] | str | None) -> dict[str, Any] | str | None:
    if args is None:
        return None
    if isinstance(args, str):
        try:
            args = json.loads(args)
        except Exception:
            return args[:500]
    if isinstance(args, dict):
        # Keep keys but truncate long values for privacy/size.
        trimmed: dict[str, Any] = {}
        for k, v in args.items():
            s = json.dumps(v)
            trimmed[k] = s[:500] + "..." if len(s) > 500 else v
        return trimmed
    return str(args)[:500]


def summarize_content(content: Any) -> Any:
    if content is None:
        return None
    if isinstance(content, str):
        return content[:4000]
    if isinstance(content, list):
        # Keep types/keys, truncate text values.
        out = []
        for item in content:
            if isinstance(item, dict) and item.get("type") == "text":
                text = item.get("text", "")
                out.append({"type": "text", "text": text[:1000]})
            else:
                out.append(item)
        return out
    return str(content)[:2000]


def parse_sse(response_bytes: bytes) -> list[dict[str, Any]]:
    """Parse Server-Sent Events into a list of JSON data objects."""
    events: list[dict[str, Any]] = []
    text = response_bytes.decode("utf-8", errors="replace")
    current_data: list[str] = []
    for raw_line in text.splitlines():
        line = raw_line.rstrip("\r")
        if line.startswith("data: "):
            current_data.append(line[6:])
        elif line == "":
            if current_data:
                payload = "".join(current_data)
                current_data = []
                if payload.strip() == "[DONE]":
                    continue
                try:
                    events.append(json.loads(payload))
                except json.JSONDecodeError:
                    pass
        elif line.startswith(":"):
            # Comment line; ignore.
            continue
    if current_data:
        payload = "".join(current_data)
        if payload.strip() != "[DONE]":
            try:
                events.append(json.loads(payload))
            except json.JSONDecodeError:
                pass
    return events


def reconstruct_chat_output(sse_events: list[dict[str, Any]]) -> dict[str, Any]:
    """Best-effort reconstruction of the assistant message from chat SSE deltas."""
    message: dict[str, Any] = {"role": "assistant", "content": "", "tool_calls": []}
    usage: dict[str, Any] | None = None
    model: str | None = None
    for ev in sse_events:
        if not isinstance(ev, dict):
            continue
        if "model" in ev and model is None:
            model = ev["model"]
        if "usage" in ev and ev["usage"]:
            usage = ev["usage"]
        for choice in ev.get("choices", []):
            delta = choice.get("delta", {})
            content = delta.get("content")
            if isinstance(content, str):
                message["content"] = (message.get("content") or "") + content
            tool_calls = delta.get("tool_calls")
            if isinstance(tool_calls, list):
                for tc in tool_calls:
                    idx = tc.get("index")
                    if idx is None:
                        message["tool_calls"].append(tc)
                        continue
                    while len(message["tool_calls"]) <= idx:
                        message["tool_calls"].append({})
                    existing = message["tool_calls"][idx]
                    if isinstance(existing, dict) and isinstance(tc, dict):
                        for k, v in tc.items():
                            if k == "index":
                                continue
                            if k == "function":
                                if "function" not in existing:
                                    existing["function"] = {}
                                if isinstance(existing["function"], dict) and isinstance(v, dict):
                                    for fk, fv in v.items():
                                        existing["function"][fk] = (existing["function"].get(fk) or "") + fv
                                else:
                                    existing["function"] = v
                            else:
                                existing[k] = (existing.get(k) or "") + v
                    else:
                        message["tool_calls"][idx] = tc
    return {"message": message, "usage": usage, "model": model}


def parse_chat_response(body: bytes) -> dict[str, Any]:
    """Parse a non-streaming chat completion response."""
    try:
        data = json.loads(body.decode("utf-8", errors="replace"))
    except json.JSONDecodeError:
        return {}
    choice = (data.get("choices") or [{}])[0]
    return {
        "message": choice.get("message", {}),
        "usage": data.get("usage"),
        "model": data.get("model"),
    }


def parse_responses_stream(sse_events: list[dict[str, Any]]) -> dict[str, Any]:
    """Best-effort parse of the Responses API SSE stream."""
    output_items: list[dict[str, Any]] = []
    usage: dict[str, Any] | None = None
    model: str | None = None
    for ev in sse_events:
        if not isinstance(ev, dict):
            continue
        if "model" in ev and model is None:
            model = ev["model"]
        if "usage" in ev and ev["usage"]:
            usage = ev["usage"]
        item = ev.get("item") or ev.get("output_item") or ev.get("delta", {}).get("item")
        if isinstance(item, dict):
            output_items.append(item)
    return {"output_items": output_items, "usage": usage, "model": model}


def parse_responses_response(body: bytes) -> dict[str, Any]:
    try:
        data = json.loads(body.decode("utf-8", errors="replace"))
    except json.JSONDecodeError:
        return {}
    return {
        "output_items": data.get("output", []),
        "usage": data.get("usage"),
        "model": data.get("model"),
    }


def emit_model_and_tool_events(
    endpoint: str,
    request_body: dict[str, Any],
    response_bytes: bytes,
    duration_ms: float,
    streamed: bool,
) -> None:
    """Emit AFR events from a captured request/response pair."""
    if endpoint.endswith("/chat/completions"):
        if streamed:
            parsed = reconstruct_chat_output(parse_sse(response_bytes))
        else:
            parsed = parse_chat_response(response_bytes)
        message = parsed.get("message") or {}
        model = parsed.get("model") or request_body.get("model", "unknown")
        usage = parsed.get("usage")

        input_summary = summarize_messages(request_body.get("messages", []))
        output_summary = {
            "role": message.get("role", "assistant"),
            "content_summary": summarize_content(message.get("content")),
            "tool_call_count": len(message.get("tool_calls", [])),
        }

        emit_event(
            "model_call",
            "codex_agent_turn",
            {
                "model": model,
                "provider": "openai",
                "endpoint": endpoint,
                "input": input_summary,
                "output": output_summary,
                "usage": usage,
                "duration_ms": duration_ms,
                "streamed": streamed,
            },
        )

        for tc in message.get("tool_calls", []):
            fn = tc.get("function", {}) if isinstance(tc, dict) else {}
            emit_event(
                "tool_call",
                "codex_tool_call",
                {
                    "tool": fn.get("name") if isinstance(fn, dict) else None,
                    "args": summarize_tool_args(fn.get("arguments") if isinstance(fn, dict) else None),
                    "tool_call_id": tc.get("id") if isinstance(tc, dict) else None,
                    "model": model,
                },
            )

        # Detect tool-result messages in the *next* request.  The proxy does not
        # keep session state, so we inspect the current request body for messages
        # whose role is "tool".
        for msg in request_body.get("messages", []):
            if isinstance(msg, dict) and msg.get("role") == "tool":
                emit_event(
                    "tool_call",
                    "codex_tool_result",
                    {
                        "tool_call_id": msg.get("tool_call_id"),
                        "result_summary": summarize_content(msg.get("content")),
                        "model": model,
                    },
                )

    elif endpoint.endswith("/responses"):
        if streamed:
            parsed = parse_responses_stream(parse_sse(response_bytes))
        else:
            parsed = parse_responses_response(response_bytes)
        model = parsed.get("model") or request_body.get("model", "unknown")
        usage = parsed.get("usage")
        output_items = parsed.get("output_items", [])
        tool_calls = [it for it in output_items if isinstance(it, dict) and it.get("type") == "function_call"]

        input_summary = {
            "input": request_body.get("input"),
            "tools_count": len(request_body.get("tools", [])),
        }
        output_summary = {
            "output_item_count": len(output_items),
            "tool_call_count": len(tool_calls),
        }

        emit_event(
            "model_call",
            "codex_agent_turn",
            {
                "model": model,
                "provider": "openai",
                "endpoint": endpoint,
                "input": input_summary,
                "output": output_summary,
                "usage": usage,
                "duration_ms": duration_ms,
                "streamed": streamed,
            },
        )

        for tc in tool_calls:
            emit_event(
                "tool_call",
                "codex_tool_call",
                {
                    "tool": tc.get("name"),
                    "args": summarize_tool_args(tc.get("arguments")),
                    "tool_call_id": tc.get("call_id"),
                    "model": model,
                },
            )

        for it in output_items:
            if isinstance(it, dict) and it.get("type") == "function_call_output":
                emit_event(
                    "tool_call",
                    "codex_tool_result",
                    {
                        "tool_call_id": it.get("call_id"),
                        "result_summary": summarize_content(it.get("output")),
                        "model": model,
                    },
                )

    else:
        # Other endpoints: minimal log event only.
        emit_event(
            "log",
            "codex_agent_turn",
            {
                "endpoint": endpoint,
                "duration_ms": duration_ms,
                "streamed": streamed,
            },
        )


class ProxyHandler(BaseHTTPRequestHandler):
    """Forward requests to the upstream OpenAI API and capture AFR events."""

    protocol_version = "HTTP/1.1"

    def log_message(self, format: str, *args: Any) -> None:
        _log(format % args)

    def _send_error(self, code: int, message: str) -> None:
        body = json.dumps({"error": message}).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self) -> None:  # noqa: N802
        api_key = os.environ.get("OPENAI_API_KEY", "").strip()
        if not api_key:
            self._send_error(401, "OPENAI_API_KEY not set")
            return

        upstream_base = os.environ.get("OPENAI_API_BASE", DEFAULT_OPENAI_API_BASE).rstrip("/")
        upstream_url = f"{upstream_base}{self.path}"

        content_length = int(self.headers.get("Content-Length", 0))
        request_body = self.rfile.read(content_length) if content_length > 0 else b""
        try:
            request_json = json.loads(request_body.decode("utf-8", errors="replace")) if request_body else {}
        except json.JSONDecodeError:
            request_json = {}

        # Drop the original Authorization so we always use the caller's key.
        forwarded_headers: dict[str, str] = {}
        for header, value in self.headers.items():
            lower = header.lower()
            if lower in ("host", "content-length", "authorization", "accept-encoding"):
                continue
            forwarded_headers[header] = value
        forwarded_headers["Authorization"] = f"Bearer {api_key}"
        forwarded_headers["Content-Type"] = "application/json"

        req = urllib.request.Request(
            upstream_url,
            data=request_body,
            headers=forwarded_headers,
            method="POST",
        )

        start = time.perf_counter()
        response_buffer = bytearray()
        streamed = False
        status_code = 502
        response_headers: list[tuple[str, str]] = []
        try:
            with urllib.request.urlopen(req, timeout=300) as upstream:
                status_code = upstream.getcode()
                upstream_headers = upstream.headers

                # Determine whether upstream is streaming (SSE).
                content_type = upstream_headers.get("Content-Type", "")
                streamed = "text/event-stream" in content_type or request_json.get("stream") is True

                for header, value in upstream_headers.items():
                    if header.lower() in ("transfer-encoding", "content-length"):
                        continue
                    response_headers.append((header, value))

                while True:
                    chunk = upstream.read(8192)
                    if not chunk:
                        break
                    response_buffer.extend(chunk)
        except urllib.error.HTTPError as exc:
            status_code = exc.code
            error_body = exc.read()
            response_buffer.extend(error_body)
            for header, value in exc.headers.items():
                if header.lower() in ("transfer-encoding", "content-length"):
                    continue
                response_headers.append((header, value))
        except Exception as exc:
            _log(f"Upstream request failed: {exc}")
            self._send_error(502, f"Upstream request failed: {exc}")
            return

        body = bytes(response_buffer)
        self.send_response(status_code)
        for header, value in response_headers:
            self.send_header(header, value)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        try:
            self.wfile.write(body)
            self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError):
            pass

        duration_ms = round((time.perf_counter() - start) * 1000, 2)

        # Emit events in the background so the proxy stays responsive.
        def emit() -> None:
            try:
                emit_model_and_tool_events(
                    self.path,
                    request_json,
                    bytes(response_buffer),
                    duration_ms,
                    streamed,
                )
            except Exception as exc:
                _log(f"Event emission failed: {exc}")

        threading.Thread(target=emit, daemon=True).start()

    def do_GET(self) -> None:  # noqa: N802
        self._proxy_read("GET")

    def do_DELETE(self) -> None:  # noqa: N802
        self._proxy_write("DELETE")

    def _proxy_read(self, method: str) -> None:
        api_key = os.environ.get("OPENAI_API_KEY", "").strip()
        if not api_key:
            self._send_error(401, "OPENAI_API_KEY not set")
            return
        upstream_base = os.environ.get("OPENAI_API_BASE", DEFAULT_OPENAI_API_BASE).rstrip("/")
        upstream_url = f"{upstream_base}{self.path}"
        forwarded_headers = {"Authorization": f"Bearer {api_key}"}
        for header, value in self.headers.items():
            if header.lower() in ("host", "authorization"):
                continue
            forwarded_headers[header] = value
        try:
            req = urllib.request.Request(upstream_url, headers=forwarded_headers, method=method)
            with urllib.request.urlopen(req, timeout=120) as upstream:
                body = upstream.read()
                self.send_response(upstream.getcode())
                for header, value in upstream.headers.items():
                    if header.lower() == "transfer-encoding":
                        continue
                    self.send_header(header, value)
                if "content-length" not in (h.lower() for h in upstream.headers):
                    self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
        except urllib.error.HTTPError as exc:
            body = exc.read()
            self.send_response(exc.code)
            for header, value in exc.headers.items():
                if header.lower() == "transfer-encoding":
                    continue
                self.send_header(header, value)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        except Exception as exc:
            _log(f"Upstream {method} failed: {exc}")
            self._send_error(502, f"Upstream {method} failed: {exc}")

    def _proxy_write(self, method: str) -> None:
        api_key = os.environ.get("OPENAI_API_KEY", "").strip()
        if not api_key:
            self._send_error(401, "OPENAI_API_KEY not set")
            return
        upstream_base = os.environ.get("OPENAI_API_BASE", DEFAULT_OPENAI_API_BASE).rstrip("/")
        upstream_url = f"{upstream_base}{self.path}"
        content_length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(content_length) if content_length > 0 else b""
        forwarded_headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
        for header, value in self.headers.items():
            if header.lower() in ("host", "content-length", "authorization"):
                continue
            forwarded_headers[header] = value
        try:
            req = urllib.request.Request(upstream_url, data=body, headers=forwarded_headers, method=method)
            with urllib.request.urlopen(req, timeout=120) as upstream:
                resp = upstream.read()
                self.send_response(upstream.getcode())
                for header, value in upstream.headers.items():
                    if header.lower() == "transfer-encoding":
                        continue
                    self.send_header(header, value)
                self.send_header("Content-Length", str(len(resp)))
                self.end_headers()
                self.wfile.write(resp)
        except urllib.error.HTTPError as exc:
            resp = exc.read()
            self.send_response(exc.code)
            for header, value in exc.headers.items():
                if header.lower() == "transfer-encoding":
                    continue
                self.send_header(header, value)
            self.send_header("Content-Length", str(len(resp)))
            self.end_headers()
            self.wfile.write(resp)
        except Exception as exc:
            _log(f"Upstream {method} failed: {exc}")
            self._send_error(502, f"Upstream {method} failed: {exc}")


class StdinWatcher(threading.Thread):
    """Watch stdin and signal the server to shut down when it closes."""

    def __init__(self, server: ThreadingHTTPServer) -> None:
        super().__init__(daemon=True)
        self._server = server

    def run(self) -> None:
        try:
            while True:
                if not sys.stdin.read(1):
                    break
        except Exception:
            pass
        _log("stdin closed; shutting down proxy")
        try:
            self._server.shutdown()
        except Exception:
            pass


def find_port(preferred: int | None) -> int:
    if preferred:
        return preferred
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.bind(("127.0.0.1", 0))
    port = sock.getsockname()[1]
    sock.close()
    return port


def main() -> int:
    global _run_id, _afr_api_url, _afr_token

    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--run-id", default=os.environ.get("CODEX_AFR_RUN_ID"), help="AFR run id to attach events to")
    parser.add_argument("--afr-api-url", default=os.environ.get("AFR_API_URL", DEFAULT_AFR_API_URL), help="AFR API base URL")
    args = parser.parse_args()

    _run_id = args.run_id
    _afr_api_url = args.afr_api_url.rstrip("/")
    _afr_token = os.environ.get("AFR_API_TOKEN", "").strip() or None

    preferred_port = os.environ.get("CODEX_AFR_PROXY_PORT")
    port = find_port(int(preferred_port) if preferred_port else None)

    server = ThreadingHTTPServer(("127.0.0.1", port), ProxyHandler)

    def shutdown(_signum: int | None = None, _frame: Any = None) -> None:
        _log("Shutting down proxy")
        try:
            server.shutdown()
        except Exception:
            pass

    signal.signal(signal.SIGTERM, shutdown)

    watcher = StdinWatcher(server)
    watcher.start()

    local_url = f"http://127.0.0.1:{port}"
    print(local_url, flush=True)
    _log(f"Listening on {local_url} -> OpenAI API")

    try:
        server.serve_forever()
    finally:
        server.server_close()

    return 0


if __name__ == "__main__":
    sys.exit(main())
