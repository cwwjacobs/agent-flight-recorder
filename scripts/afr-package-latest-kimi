#!/usr/bin/env python3
"""Export the latest completed Kimi run and build a clean share package.

The package contains only:
  * the AFR JSON export for that single run
  * its matching terminal transcript
  * a receipt with checksums and provenance

Failed, running, and stale sessions are excluded because the script only
considers AFR runs whose status is `completed` and whose metadata says
`agent == "kimi"`.
"""

from __future__ import annotations

import argparse
import datetime
import hashlib
import json
import os
import shutil
import subprocess
import sys
import tarfile
from pathlib import Path


def _repo_root() -> Path:
    return Path(__file__).resolve().parent.parent


def _api_url() -> str:
    return os.environ.get("AFR_API_URL", "http://127.0.0.1:8700").rstrip("/")


def _afr_root() -> Path:
    return Path(os.environ.get("AFR_ROOT") or _repo_root())


def _afr_bin() -> Path:
    return Path(os.environ.get("AFR_BIN") or (_repo_root() / ".venv" / "bin" / "afr"))


def _run_prefix(run_id: str) -> str:
    return run_id.split("-")[0]


def _sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _afr_json(args: list[str]) -> dict | list:
    cmd = [str(_afr_bin()), "--json", "-A", _api_url(), *args]
    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    if not result.stdout.strip():
        return {}
    return json.loads(result.stdout)


def completed_kimi_runs(limit: int = 20) -> list[dict]:
    runs = _afr_json(["runs", "list", "--status", "completed", "--limit", str(limit)])
    if not isinstance(runs, list):
        return []
    return [r for r in runs if isinstance(r, dict) and r.get("metadata", {}).get("agent") == "kimi"]


def latest_completed_kimi_run_id() -> str:
    runs = completed_kimi_runs(limit=10)
    if not runs:
        raise RuntimeError("No completed Kimi run found.")
    return runs[0]["id"]


def export_run(run_id: str, output: Path) -> None:
    output.parent.mkdir(parents=True, exist_ok=True)
    cmd = [str(_afr_bin()), "-A", _api_url(), "export", run_id, "-o", str(output)]
    subprocess.run(cmd, check=True)


def build_package(run_id: str) -> dict:
    afr_root = _afr_root().resolve()
    prefix = _run_prefix(run_id)

    export_dir = afr_root / "exports"
    share_dir = afr_root / "share"
    clean_dir = share_dir / f"kimi-clean-{prefix}"
    tar_path = share_dir / f"kimi-clean-{prefix}.tar.gz"

    export_path = export_dir / f"kimi-trace-{prefix}.json"
    transcript_dir = afr_root / ".afr" / "kimi" / run_id
    transcript_path = transcript_dir / "terminal-transcript.txt"

    if not transcript_path.exists():
        raise RuntimeError(f"Transcript not found for run {run_id}: {transcript_path}")

    # Clean any previous package for this prefix so the result is deterministic.
    if clean_dir.exists():
        shutil.rmtree(clean_dir)
    if tar_path.exists():
        tar_path.unlink()

    export_run(run_id, export_path)

    clean_dir.mkdir(parents=True)
    shutil.copy2(export_path, clean_dir / export_path.name)
    shutil.copy2(transcript_path, clean_dir / transcript_path.name)

    transcript_sha = _sha256_file(transcript_path)

    receipt = {
        "run_id": run_id,
        "export_path": str((clean_dir / export_path.name).relative_to(afr_root)),
        "transcript_path": str((clean_dir / transcript_path.name).relative_to(afr_root)),
        "transcript_sha256": transcript_sha,
        "package_path": str(tar_path.relative_to(afr_root)),
        "raw_transcript_is_sensitive": True,
        "created_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "note": "Raw terminal transcript is sensitive; do not share unredacted.",
    }

    receipt_path = clean_dir / "receipt.json"
    with receipt_path.open("w", encoding="utf-8") as f:
        json.dump(receipt, f, indent=2)
        f.write("\n")

    with tarfile.open(tar_path, "w:gz") as tar:
        tar.add(clean_dir, arcname=clean_dir.name)

    package_sha = _sha256_file(tar_path)
    receipt["package_sha256"] = package_sha

    # Update the receipt on disk with the package checksum.
    with receipt_path.open("w", encoding="utf-8") as f:
        json.dump(receipt, f, indent=2)
        f.write("\n")

    # Also write a fresh tarball with the updated receipt.
    if tar_path.exists():
        tar_path.unlink()
    with tarfile.open(tar_path, "w:gz") as tar:
        tar.add(clean_dir, arcname=clean_dir.name)
    package_sha = _sha256_file(tar_path)
    receipt["package_sha256"] = package_sha

    return {
        "run_id": run_id,
        "prefix": prefix,
        "export_path": str(export_path),
        "transcript_path": str(transcript_path),
        "clean_dir": str(clean_dir),
        "tar_path": str(tar_path),
        "package_sha256": package_sha,
        "transcript_sha256": transcript_sha,
        "receipt": receipt,
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="Build a clean share package for the latest completed Kimi run.")
    parser.add_argument("run_id", nargs="?", help="Run UUID or prefix (default: latest completed Kimi run)")
    args = parser.parse_args()

    try:
        if args.run_id:
            run_id = args.run_id.strip().lower()
            if len(run_id) != 36 or run_id.count("-") != 4:
                matches = [r["id"] for r in completed_kimi_runs() if str(r.get("id", "")).lower().startswith(run_id)]
                if len(matches) != 1:
                    print(f"Could not resolve run prefix {args.run_id!r} to a single completed Kimi run.", file=sys.stderr)
                    return 1
                run_id = matches[0]
        else:
            run_id = latest_completed_kimi_run_id()

        result = build_package(run_id)

        print(f"Packaged latest completed Kimi run: {result['run_id']}")
        print(f"  export:    {result['export_path']}")
        print(f"  transcript: {result['transcript_path']}")
        print(f"  clean dir: {result['clean_dir']}")
        print(f"  tarball:   {result['tar_path']}")
        print(f"  package sha256: {result['package_sha256']}")

    except subprocess.CalledProcessError as exc:
        print(f"AFR CLI command failed: {exc}", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr, file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
